    {
      "id": "oge-5",
      "name": "Задача 5. Задание 15 (ОГЭ). Высота в равнобедренном треугольнике",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В равнобедренном треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " с основанием "
            },
            {
              "type": "math-inline",
              "latex": "AC"
            },
            {
              "type": "text",
              "html": " боковая сторона "
            },
            {
              "type": "math-inline",
              "latex": "AB = 13"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "\\cos A = \\frac{5}{13}"
            },
            {
              "type": "text",
              "html": ". Найдите высоту, проведённую к основанию."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В равнобедренном треугольнике высота "
            },
            {
              "type": "math-inline",
              "latex": "BH"
            },
            {
              "type": "text",
              "html": ", проведённая к основанию, является также медианой и биссектрисой."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Рассмотрим "
            },
            {
              "type": "math-inline",
              "latex": "\\triangle ABH"
            },
            {
              "type": "text",
              "html": ": "
            },
            {
              "type": "math-inline",
              "latex": "\\angle H = 90^\\circ"
            },
            {
              "type": "text",
              "html": ", гипотенуза "
            },
            {
              "type": "math-inline",
              "latex": "AB = 13"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "\\cos A = \\frac{AH}{AB} = \\frac{5}{13} \\Rightarrow AH = 5"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "По теореме Пифагора:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "BH^2 = AB^2 - AH^2 = 169 - 25 = 144 \\Rightarrow BH = 12"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 12."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
