    {
      "id": "oge-1",
      "name": "Задача 1. Задание 15 (ОГЭ). Косинус острого угла",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " угол "
            },
            {
              "type": "math-inline",
              "latex": "C"
            },
            {
              "type": "text",
              "html": " равен "
            },
            {
              "type": "math-inline",
              "latex": "90^\\circ"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "BC = 8"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "AB = 10"
            },
            {
              "type": "text",
              "html": ". Найдите "
            },
            {
              "type": "math-inline",
              "latex": "\\cos A"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В прямоугольном треугольнике косинус острого угла равен отношению прилежащего катета к гипотенузе."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Для угла "
            },
            {
              "type": "math-inline",
              "latex": "A"
            },
            {
              "type": "text",
              "html": " прилежащий катет — "
            },
            {
              "type": "math-inline",
              "latex": "AC"
            },
            {
              "type": "text",
              "html": ". Найдём его по теореме Пифагора:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "AC^2 = AB^2 - BC^2 = 100 - 64 = 36 \\Rightarrow AC = 6"
        },
        {
          "type": "math-display",
          "latex": "\\cos A = \\frac{AC}{AB} = \\frac{6}{10} = 0,6"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 0,6."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
              "html": "<a href=\"https://math-oge.sdamgia.ru/problem?id=356170\" target=\"_blank\">Решу ОГЭ: Задание № 356170</a>."
            }
          ]
        }
      ]
    },
    {
      "id": "oge-2",
      "name": "Задача 2. Задание 15 (ОГЭ). Площадь треугольника",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " известно, что "
            },
            {
              "type": "math-inline",
              "latex": "AB = 10"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "AC = 14"
            },
            {
              "type": "text",
              "html": ", а угол "
            },
            {
              "type": "math-inline",
              "latex": "A = 150^\\circ"
            },
            {
              "type": "text",
              "html": ". Найдите площадь треугольника."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Площадь треугольника равна половине произведения двух сторон на синус угла между ними:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "S = \\frac{1}{2} \\cdot AB \\cdot AC \\cdot \\sin A"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "math-inline",
              "latex": "\\sin 150^\\circ = \\sin(180^\\circ - 30^\\circ) = \\sin 30^\\circ = \\frac{1}{2}"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "S = \\frac{1}{2} \\cdot 10 \\cdot 14 \\cdot \\frac{1}{2} = 35"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 35."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
