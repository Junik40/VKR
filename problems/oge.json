        }
      ]
    },
    {
      "id": "oge-3",
      "name": "Задача 3. Задание 15 (ОГЭ). Теорема синусов",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " угол "
            },
            {
              "type": "math-inline",
              "latex": "A"
            },
            {
              "type": "text",
              "html": " равен "
            },
            {
              "type": "math-inline",
              "latex": "45^\\circ"
            },
            {
              "type": "text",
              "html": ", угол "
            },
            {
              "type": "math-inline",
              "latex": "B"
            },
            {
              "type": "text",
              "html": " — "
            },
            {
              "type": "math-inline",
              "latex": "30^\\circ"
            },
            {
              "type": "text",
              "html": ", "
            },
            {
              "type": "math-inline",
              "latex": "BC = 3\\sqrt{2}"
            },
            {
              "type": "text",
              "html": ". Найдите "
            },
            {
              "type": "math-inline",
              "latex": "AC"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "По теореме синусов стороны пропорциональны синусам противолежащих углов:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "\\frac{AC}{\\sin B} = \\frac{BC}{\\sin A}"
        },
        {
          "type": "math-display",
          "latex": "\\frac{AC}{\\sin 30^\\circ} = \\frac{3\\sqrt{2}}{\\sin 45^\\circ}"
        },
        {
          "type": "math-display",
          "latex": "\\frac{AC}{1/2} = \\frac{3\\sqrt{2}}{\\sqrt{2}/2}"
        },
        {
          "type": "math-display",
          "latex": "2AC = \\frac{3\\sqrt{2} \\cdot 2}{\\sqrt{2}} = 6 \\Rightarrow AC = 3"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 3."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
              "html": "<a href=\"https://math-oge.sdamgia.ru/problem?id=356170\" target=\"_blank\">Решу ОГЭ: Задание № 356170</a>."
            }
          ]
        }
      ]
    },
