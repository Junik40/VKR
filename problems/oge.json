    {
      "id": "oge-9",
      "name": "Задача 9. Задание 18 (ОГЭ). Тригонометрия на клетчатой бумаге",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "На клетчатой бумаге с размером клетки "
            },
            {
              "type": "math-inline",
              "latex": "1 \\times 1"
            },
            {
              "type": "text",
              "html": " изображён угол. Найдите тангенс этого угла."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Тангенс угла на клетчатой бумаге можно найти как отношение противолежащего катета к прилежащему в прямоугольном треугольнике, построенном на сторонах угла."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Достроим угол до прямоугольного треугольника, опустив перпендикуляр из одной точки на горизонтальную линию. Если противолежащий катет равен "
            },
            {
              "type": "math-inline",
              "latex": "3"
            },
            {
              "type": "text",
              "html": " клетки, а прилежащий — "
            },
            {
              "type": "math-inline",
              "latex": "4"
            },
            {
              "type": "text",
              "html": " клетки, то:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "\\operatorname{tg}\\alpha = \\frac{3}{4} = 0,75"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 0,75."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
              "html": "<a href=\"https://math-oge.sdamgia.ru/test?filter=all&category_id=14\" target=\"_blank\">Решу ОГЭ: Категория «Тригонометрия»</a>."
            }
          ]
        }
      ]
    },
    {
      "id": "oge-10",
      "name": "Задача 10. Задание 15 (ОГЭ). Синус внешнего угла",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "В треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " угол "
            },
            {
              "type": "math-inline",
              "latex": "C"
            },
            {
              "type": "text",
              "html": " равен "
            },
            {
              "type": "math-inline",
              "latex": "90^\\circ"
            },
            {
              "type": "text",
              "html": ", , "
            },
            {
              "type": "math-inline",
              "latex": "BC = 5"
            },
            {
              "type": "text",
              "html": ". Найдите синус внешнего угла при вершине "
            },
            {
              "type": "math-inline",
              "latex": "A"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Найдём катет "
            },
            {
              "type": "math-inline",
              "latex": "AC"
            },
            {
              "type": "text",
              "html": " по теореме Пифагора:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "AC^2 = AB^2 - BC^2 = 169 - 25 = 144 \\Rightarrow AC = 12"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Синус внутреннего угла "
            },
            {
              "type": "math-inline",
              "latex": "A"
            },
            {
              "type": "text",
              "html": ":"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "\\sin A = \\frac{BC}{AB} = \\frac{5}{13}"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Синус внешнего угла равен синусу внутреннего: "
            },
            {
              "type": "math-inline",
              "latex": "\\sin(180^\\circ - A) = \\sin A"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> "
            },
            {
              "type": "math-inline",
              "latex": "\\frac{5}{13}"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
              "html": "<a href=\"https://math-oge.sdamgia.ru/problem?id=284233\" target=\"_blank\">Решу ОГЭ: Задание № 284233</a>."
            }
          ]
        }
      ]
    }
  ]
