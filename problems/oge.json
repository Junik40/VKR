    {
      "id": "oge-6",
      "name": "Задача 6. Задание 15 (ОГЭ). Радиус описанной окружности",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Боковая сторона равнобедренного треугольника равна "
            },
            {
              "type": "math-inline",
              "latex": "4"
            },
            {
              "type": "text",
              "html": ". Угол при вершине, противолежащий основанию, равен "
            },
            {
              "type": "math-inline",
              "latex": "120^\\circ"
            },
            {
              "type": "text",
              "html": ". Найдите диаметр окружности, описанной около этого треугольника."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Пусть в треугольнике "
            },
            {
              "type": "math-inline",
              "latex": "ABC"
            },
            {
              "type": "text",
              "html": " равны "
            },
            {
              "type": "math-inline",
              "latex": "AB = AC = 4"
            },
            {
              "type": "text",
              "html": ", угол "
            },
            {
              "type": "math-inline",
              "latex": "A = 120^\\circ"
            },
            {
              "type": "text",
              "html": ". Найдём "
            },
            {
              "type": "math-inline",
              "latex": "BC"
            },
            {
              "type": "text",
              "html": " по теореме косинусов:"
            }
          ]
        },
        {
          "type": "math-display",
          "latex": "BC^2 = AB^2 + AC^2 - 2\\cdot AB\\cdot AC\\cdot\\cos 120^\\circ = 16 + 16 - 32\\cdot\\left(-\\tfrac{1}{2}\\right) = 48"
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "math-inline",
              "latex": "BC = 4\\sqrt{3}"
            },
            {
              "type": "text",
              "html": ". По теореме синусов: "
            },
            {
              "type": "math-inline",
              "latex": "2R = \\frac{BC}{\\sin A} = \\frac{4\\sqrt{3}}{\\sin 120^\\circ} = \\frac{4\\sqrt{3}}{\\sqrt{3}/2} = 8"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> 8."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Источник: "
            },
            {
              "type": "html",
              "html": "<a href=\"https://math-oge.sdamgia.ru/problem?id=316346\" target=\"_blank\">Решу ОГЭ: Задание № 316346</a>."
            }
          ]
        }
      ]
    },
    {
