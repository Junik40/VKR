            {
              "type": "math-inline",
              "latex": "AC"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "По теореме косинусов:"
            }
          ]
        },
        {
          "type": "math-display",
