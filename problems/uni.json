    {
      "id": "uni-9",
      "name": "Задача 9. Экстремумы на отрезке и синус суммы углов (Старый)",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Найдите наибольшее и наименьшее значения функции "
            },
            {
              "type": "math-inline",
              "latex": "f(x) = \\sqrt{3}\\sin x - \\cos x"
            },
            {
              "type": "text",
              "html": " на отрезке "
            },
            {
              "type": "math-inline",
              "latex": "\\bigl[0,\\,\\pi\\bigr]"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> max=2, min=-1."
            }
          ]
        }
      ]
    },
    {
      "id": "uni-10",
      "name": "Задача 10. Ряд Тейлора (Приближенные вычисления)",
      "statement": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "text",
              "html": "Замените "
            },
            {
              "type": "math-inline",
              "latex": "\\sin x"
            },
            {
              "type": "text",
              "html": " первыми двумя членами ряда Тейлора в окрестности нуля и оцените погрешность для "
            },
            {
              "type": "math-inline",
              "latex": "x=0.1"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ],
      "solution": [
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "math-inline",
              "latex": "\\sin x = x - \\frac{x^3}{6} + O(x^5)"
            },
            {
              "type": "text",
              "html": ". Для "
            },
            {
              "type": "math-inline",
              "latex": "x=0.1"
            },
            {
              "type": "text",
              "html": ": "
            },
            {
              "type": "math-inline",
              "latex": "\\sin 0.1 \\approx 0.1 - 0.000167 = 0.099833"
            },
            {
              "type": "text",
              "html": ". Погрешность "
            },
            {
              "type": "math-inline",
              "latex": "\\sim 10^{-5}"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        },
        {
          "type": "paragraph",
          "parts": [
            {
              "type": "html",
              "html": "<strong>Ответ:</strong> "
            },
            {
              "type": "math-inline",
              "latex": "x - \\frac{x^3}{6}"
            },
            {
              "type": "text",
              "html": "."
            }
          ]
        }
      ]
    }
  ]
}
